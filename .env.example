# Spotify Developer Console credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# OAuth redirect — must match exactly what's registered in Spotify Dev Console
# Dev:  http://localhost:3001/api/auth/callback
# Prod: https://your-railway-url.up.railway.app/api/auth/callback
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/auth/callback

# After OAuth, the server redirects back to the frontend.
# Dev:  leave empty (redirects to relative /host)
# Prod: https://joavn.dev/versed
FRONTEND_URL=

PORT=3001
NODE_ENV=development
